{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "subscriptionTier": { "type": "string", "enum": ["starter", "pro", "agency"] },
        "apiCreditsRemaining": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLoginAt": { "type": "string", "format": "date-time" },
        "country": { "type": "string" }
      },
      "required": ["id", "email", "subscriptionTier", "apiCreditsRemaining", "createdAt"]
    },
    "TrendSnapshot": {
      "title": "TrendSnapshot",
      "description": "A single trending topic discovered by AI",
      "type": "object",
      "properties": {
        "trendName": { "type": "string" },
        "trendDescription": { "type": "string" },
        "viralityScore": { "type": "integer" },
        "searchVolumeDelta": { "type": "number" },
        "socialVelocity": { "type": "number" },
        "sourcePlatform": { "type": "string" },
        "suggestedLeadMagnets": { "type": "array", "items": { "type": "string" } },
        "vertical": { "type": "string" },
        "geoTarget": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["trendName", "trendDescription", "viralityScore", "searchVolumeDelta", "socialVelocity", "sourcePlatform", "suggestedLeadMagnets", "vertical", "geoTarget", "userId", "createdAt"]
    },
    "GeneratedAsset": {
      "title": "GeneratedAsset",
      "description": "AI generated marketing asset",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "campaignId": { "type": "string" },
        "assetType": { "type": "string", "enum": ["video_script", "landing_page_copy", "cta_copy"] },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "modelUsed": { "type": "string" },
        "estimatedCost": { "type": "number" }
      },
      "required": ["userId", "assetType", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/trend_snapshots/{trendId}": {
      "schema": "TrendSnapshot",
      "description": "AI discovered trends"
    },
    "/generated_assets/{assetId}": {
      "schema": "GeneratedAsset",
      "description": "Saved AI assets"
    }
  }
}
